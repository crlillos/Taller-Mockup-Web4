<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Cita</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>
<body class="page-transition">

<header id="main-header">
    <div class="logo">MOCK<span>UP</span> <span>ADMIN</span></div>
</header>

<main style="padding-top: 120px; max-width: 600px; margin: 0 auto;">
    <h2 class="reveal is-visible">Editar Cita</h2>

    <div class="contacto-box reveal is-visible" style="padding: 25px;">
        <form action="/actualizar_cita/{{ cita.id }}" method="POST" style="display:flex; flex-direction:column; gap:15px;">

            <label>Cliente:</label>
            <input type="text" name="cliente" value="{{ cita.cliente }}" required>

            <label>Fecha:</label>
            <input type="date" name="fecha" value="{{ cita.fecha }}" required>

            <label>Servicio:</label>
            <input type="text" name="servicio" value="{{ cita.servicio }}" required>

            <label>Teléfono:</label>
            <input type="text" name="telefono" value="{{ cita.telefono }}" required>

            <button class="btn-editar" type="submit">Guardar Cambios</button>
        </form>
    </div>
</main>

</body>
</html>
